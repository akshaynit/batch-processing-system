# ---- Inference (DigitalOcean Serverless Inference, OpenAI-compatible) ----
LLM_BASE_URL=https://inference.do-ai.run/v1/
LLM_API_KEY=replace-with-your-model-access-key
# Pick a model your DO subscription tier can access (open-weights models are
# cheapest for high-throughput testing), e.g. mistral-3-14B, openai-gpt-oss-20b,
# gemma-4-31B-it, llama3.3-70b-instruct. List them: GET {LLM_BASE_URL}models.
LLM_MODEL=mistral-3-14B
LLM_TIMEOUT_SECONDS=60

# ---- Worker pool / backpressure ----
WORKER_POOL_SIZE=4
MAX_CONCURRENCY=10
CHUNK_SIZE=50
RETRY_MAX_ATTEMPTS=5
RETRY_BASE=1.0
RETRY_FACTOR=2.0
RETRY_CAP=30.0
LEASE_TTL_SECONDS=120
HEARTBEAT_SECONDS=30

# ---- Storage backend (local now; s3 = DigitalOcean Spaces later) ----
STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=./data/results
# SPACES_KEY=
# SPACES_SECRET=
# SPACES_REGION=nyc3
# SPACES_BUCKET=
# SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com

# ---- Database ----
DATABASE_URL=postgresql+asyncpg://batch:batch@localhost:5432/batch

# ---- Observability ----
SERVICE_NAME=batch-processing-system
ENVIRONMENT=local
LOG_LEVEL=INFO
LOG_FORMAT=json            # json (structured, for shipping) | console (human-readable)
# Optional rotating file log (in addition to stdout). Leave empty to log only to
# stdout (recommended for containers). In Docker, ./data -> /app/data persists it.
LOG_FILE=                  # e.g. /app/data/logs/app.log  (or ./data/logs/app.log locally)
LOG_FILE_MAX_BYTES=10000000
LOG_FILE_BACKUP_COUNT=5
METRICS_ENABLED=true       # exposes GET /metrics (Prometheus text format)
# Error tracking is off unless a DSN is provided (pip install ".[observability]"):
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# ---- Validation guardrails ----
MAX_ITEMS_PER_BATCH=200000
MAX_PROMPT_TOKENS=120000
MAX_OUTPUT_TOKENS=2048
MIN_PROMPT_CHARS=1
COST_BUDGET_USD=50
REJECT_DUPLICATE_IDS=true
